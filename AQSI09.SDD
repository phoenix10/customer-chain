  //20110705 add by 37419 for Z96-11051600002  ↑ 
TOOLBAR:  重取材料单价 //20111124 ADD BY 38130 FOR Z10-11112400001	 

如自动报价单头档(COPEN)没有 毛利率(EN057)字段，则动态创建   //20130216 ADD BY 600792 FOR Z02-13021600001

字段说明:
  单头:
    1.单别(EN001)
       * 不可空白
       * [F2]单据性质信息 (CMSMQ-01):WHERE MQ003='21' AND USRID     
       * 仅能输入单据性质(MQ003)为'21'(报价单单据者)
         Validator:CMSMQ-01 CHECK 单据性质档 WHERE MQ001=单别 and MQ003='21' AND USRID
         Validator:E-17 CHECK 报价单据权限档 WHERE EJ001=单别  USRID
         Msg code:E+100007 "此单别不存在或单据性质不符!" 
         Validator:E-24 WHERE 报价单别=EK001
         IF E-24 返回值为空 THEN//未设权限
            报价分类(EN021) ENABLE 且不可空白
            单身可用
         ELSE
            报价分类(EN021)为最大输入顺序的报价分类
            依序按报价分类展开单身 
            IF E-17的返回值为非空 THEN           
               单身按返回的输入顺序来确认可用的报价分类页签
               例返回值:输入顺序=2,则第二个页签可用,其它READ ONLY
            ELSE
               所有页签均不可用
            ENDIF
         ENDIF         
       * DISPLAY 单据名称         
       * 若此单别的编码方式为自动编号者，输入单别后跳至单据日期字段
       * 连续新增时DEFAULT前一笔单别 
     //20110705 add by 37419 for Z96-11051600002  ↓                                
      　* Validator:ADMMQ-02，CHECK 电子表单单头档，WHERE 程序编号(AQSI09)、单别      
          IF NOT NULL
             DEFAULT 签核状态码 (EN056)=0.待处理
          ELSE
             DEFAULT 签核状态码 (EN056)=N.不运行电子签核
          ENDIF
    //20110705 add by 37419 for Z96-11051600002  ↑   
    2.单号(EN002)
      * 不可空白
      * 编码方式为「4.手动编号」须自行输入不可空白，并CHECK 是否重覆
        ，其余自动Default单号
        Msg Code:E+000003  "[%s]字段不可空白!"
        
    3.版本(EN003)
      * 不可空白 
      * DEF '0001',自动以1码流水跳号
      * Validator:E-15 WHERE 单别=:EN001 AND 单号=:EN002 取得该单号最大流水号
        以返回值+1为当前流水号
      * Validator:E-14 WHERE 单别,单号,序号 CHECK 报价单单头档，若存在 SHOW ERROR MSG 
   
    4.单据日期(EN004)
        不可空白 //20100727 add by 37419
      * IF 系统日>=库存现行年月(CMS.MA011) 
        DEFAULT SYSTEM DATE
      * CHECK DATE
      * 须>=库存现行年月(CMS.MA011) 
        Msg code:E+100013  "输入日期信息不可小于库存现行年月 !" 
        Validator:E-20  获取自动报价参数信息
      * DEFAULT 报价币种(EN022) = 币种(EA001)    
      * Default 汇率(EN018):币种+银行买入汇率(I)+单据日期 按Counter.ExchangeRate 撷取出       
      * DEFAULT 有效截止日期(EN012) = 单据日期 (TA013)+有效期(EA002)    
      * 连续新增时DEFAULT前一笔单据日期              
      * IF 停业日期(COP.MA068) <> SPACE
           单据日期(TA013) >= 停业日期(COP.MA068)时
           Msg code:E+100460  "此客户已于 [ %S ] 停业!"  传入值 '停业日期'
        ENDIF
    
    5.报价人员(EN005) 
        * 可空白                                                                           
        * [F2] 业务人员信息查询(CMSMK-01) WHERE 职务分类='3'                               
        * 非空白时                                                                         
          Validator:CMSMK-01 CHECK 职务人员档 WHERE 业务员 and 职务分类='3'                
          Msg code:E+100032 "此人员不存在或职务分类不符 !"                                 
        * SHOW 人员名称(CMS.MV002)
          
     6.报价品号(EN006)
       *不可空白
       * [F2] 品号信息查询 (INVMB-01)
         Validator:INVMB-63 CHECK 品号快捷码    
         Validator:E-16 CHECK 品号信息档 
               若存在品号基本信息档则 DEFAULT 品名(EN007),规格(EN008),报价分类(EN021)
               //20110113 add by 37419 for Z10-11011300001  ↓
               if 返回值：选配模式 (INV.MB443) <> 0.无选配 AND 品号存在 then
                  配置方案(EN054)可用
               else
               　配置方案(EN054)清空且不可用
               endif
               IF 返回值属性编号(INV.MB179)<>'' THEN
                  * Validator:INVMI-01 check 品号特征资料檔 WHERE 品号属性编号(MB179)
                  　IF 返回值:参与报价运算(INV.MI017)='Y' THEN
                       按序将特征名称(INV.MP004)与品号特征值<>SPACE(INV.MB180-199)显示在信息页签中，
                       例品号：001,其属性为色彩尺寸，特征分别是颜色，尺寸,品号特征值MB180=红色,MB181=35
                       显示：色彩尺寸
                       　　　颜色：红色
                       　　　尺寸：35
                       此组数据用以参加公式运算
                    ENDIF
               ENDIF
               //20110113 add by 37419 for Z10-11011300001  ↑ 
         IF 报价单别不做流程管控( E-24 返回值为空)  
            IF (INV.MBE01)报价分类=SPACE             
               报价分类(EN021)ENABLE ,清空报价分类,报价单位 
               报价分类开以开窗选所有的报价分类
            ELSE
               报价分类(EN021)DISABLE
            ENDIF
         ELSE            
           IF 品号报价分类(INV.MBE01)=SPACE
               报价分类(EN021)ENABLE
               报价分类(EN021)可以选择在单别限定范围内的开窗
           ELSE
               DEF 报价分类=品号报价分类(INV.MBE01) 
           ENDIF
         ENDIF   
    
       * [F3]工程品号信息查询 (E-03)                                
           *Validator:BOMMI-01 CHECK 工程品号基本信息档
            若存在BOMMI 时自动带出:DEFAULT 品名(EN007),规格(EN008),报价分类ENABLE
       * IF 品号不存在品号信息档及工程品号中 THEN
             show warning msg
             ENABLE 品名(EN007),规格(EN008),报价分类(EN021)
         ELSE
             DISABLE 品名(EN007),规格(EN008)
         ENDIF          
          报价品号变更时，则清空原报价分类和报价单位 //20100727 add by 37419  
     7.品名(EN007)
     
     8.规格(EN008)
     //20110113 add by 37419 for Z10-11011300001  ↓ 
     9.配置方案(EN054)
       if 选配模式 (INV.MB443) <> 0.无选配 and 品号为正式品号 then
          不可空白
          [F2] 配置方案查询 (COPTQ-03) WHERE TQ006='Y' AND TQ001=品号
       　　Validator: COPTQ-01  check 产品配置档 WHERE 品号 and 配置方案       
       　　MSG CODE : E+200661 '不存在此配置方案或配置方案未审核'
       　　DEFAULT 描述(COP.TQ003)
       else
       　清空且不可用
       endif
     //20110113 add by 37419 for Z10-11011300001  ↑ 
     11.报价分类(EN021)  
       *[F2] 报价分类信息查询 (E-13)where 分类代号(EN021),单据日(EN004),单据日(EN004)
       * Validator:E-37 where 分类代号(EN021),单据日(EN004),单据日(EN004) CHECK 报价信息档  then show error msg 
       * DEF 报价单位(EN009)=(EF004),基本价格(EN032)=(EF003)、最低加价比率(EN031)=(EF009)、最高加价比率(EN030)=(EF008)、
              报价基准批量(EN010)=(EF011)
              SHOW 报价分类名称 //20100727 ADD BY 37419
        //20100506 ADD BY 37419 ↓  
         IF 品号存在于INVMB中
             IF 单位<>「库存单位」(INV.MB004)
                Validator:INVMD-01，CHECK 单位换算信息档
                若不存在则SHOW:MSG W+E00003  "报价单位不存在于品号单位档中,此处将以品号单位报价,请注意维护材料用量!"
             ENDIF
         ELSE IF 品号存在于BOMMI中
            IF 单位<>「库存单位」(BOM.MI004)
                若不存在则SHOW:MSG W+E00003  "报价单位不存在于品号单位档中,此处将以品号单位报价,请注意维护材料用量!"
             ENDIF
         ELSE
             报价单位 READ ONLY
         ENDIF
        //20100506 ADD BY 37419 ↑ 
       
        若报价分类与单别设定分类不符则报错     
     12.报价单位(EN009)
        * 不可空白
          IF 品号存在于INVMB中 TEHN 
             [F2]单位信息查询(INVMD-01)
             Validator:INVMD-02，CHECK 单位换算信息档若不存在                   //20100727 ADD BY 37419
            若不存在则SHOW:MSG W+E00003  "报价单位不存在于品号单位档中,此处将以品号单位报价,请注意维护材料用量!" //20100727 ADD BY 37419
          ELSE           
             [F2]单位信息查询(INVMD-02)
            //20100727 ADD BY 37419 ↓  
            IF 品号存在于INVMB中
             IF 品号存在于BOMMI中
                IF 单位<>「库存单位」(BOM.MI004)
                   若不存在则SHOW:MSG W+E00003  "报价单位不存在于品号单位档中,此处将以品号单位报价,请注意维护材料用量!"
                ENDIF 
             ENDIF
             //20100727 ADD BY 37419 ↑  
          ENDIF
     13.报价基准批量(EN010)
        * READ ONLY 
        * 此字段必须大于0                              
          Msg code:E+100006  " [%S] 须大于零 ! " 
          
     14.交货日(EN011)
        * 此字段必须大于等于0
          Msg code:E+100012  "此字段须大于等于零 !"
          
     15.有效截止日期(EN012)
        * 不可空白
        * CHECK DATE
        * [F2]日期快手
        
     16.客户编号(EN014) 
        * 可空白,可不存在
            * [F2] 客户信息查询 (COPMA-05)
            * Validator:COPMA-61 CHECK 客户快捷码 
            * Validator:COPMA-03 CHECK 客户信息档 
             IF 不存在 THEN 
               Validator:COPMA-13 CHECK 客户信息档    
                  IF 不存在 THEN
                     Msg code:W+200287 "此客户不存在！"
                  ELSE
                     Msg code:E+200568 "你无此客户的权限！" 
                  ENDIF
             ENDIF
             DEFAULT:客户全称,税种,付款条件,价格说明,    
             IF 报价人员(EN005)='' THEN DEF 报价人员(EN005)=业务人员(MA016)  //20121224 ADD BY 600792 FOR B32-121221003
             
             DEFAULT:付款条件(EN015)=付款条件(COP.MA031)                         
           * DISPALY 「客户基本信息档」的简称
             DEFAULT 核准状况(MA097)  
           * IF 停业日期(COP.MA068) <> SPACE
                单据日期(TA013) >= 停业日期(COP.MA068)时
                Msg code:E+100460  "此客户已于 [ %S ] 停业!"  传入值 '停业日期'       
           *IF 核准状况(MA097)=2:尚待核准                  
               Msg Code :E+200136  "此客户的核准状况为尚待核准!" 
            IF 核准状况(MA097)=3:不准交易 
               Msg Code :E+200080  "此客户的核准状况为不准交易!"
                        
           * IF 共用参数设置.制药经营管理(CMSMA.MA048)='Y'
                Validator:GSPTH-01 CHECK 客户限销商品单头信息档 WHERE TH001=客户
                DEFAULT 客户限销类别(GSP.TH003)
     17.客户全称(EN017)     
        * [F2] 常用语查询 
               
     18.付款条件(EN015)
        * 可空白                                                      
        * [F2] 付款条件编号查询(CMSNA-01)                             
        * Validator:CMSNA-01 CHECK 付款条件档，若不存在 SHOW ERROR MSG
        * SHOW 付款条件名称                                                         
        * DEFAULT 付款条件(TA011)=付款条件名称(CMS.NA003)             
    
    19.价格说明(EN016) 
       * [F2] 常用语查询   
       
    20.报价币种 (EN022)
       * 不可空白                                                                  
       * [F2]币种信息查询 (CMSMF-01)                                               
       * Validator:CMSMF-01 CHECK 币种汇率档，Show Error Msg                       
       * Default 汇率:币种+银行买入汇率(I)+单据日期 按Counter.ExchangeRate 撷取出  
   
    21.税种(EN019)
       * 不可空白
       * 1.应税内含、2.应税外加、  3.零税率、4.免税、9.不计税   
       * DEFAULT '1.应税内含' 
       * IF 税种 IN ('3','4','9') 
            DEFAULT 增值税率=0
         ELSE
            DEFAULT 增值税率=「共用参数设置」的增值税率(CMS.MA004)  
         ENDI 
         
    22.税率(EN020)   
        * DEFAULT「共用参数设置」的增值税率(CMS.MA004)    
        * 显示与输入时以 5.00 % SHOW，但存入时将信息除以100存入0.0500
        * 不可小于０
          Msg Code:E+100012  "此字段必须大于等于零 !" 
          
    23.汇率(EN018)
        * [F2]币种汇率查询 (CMSMG-02)  WHERE 币种=EN022
        * 此字段必须大于0
          Msg code:E+100006  " [%S] 须大于零 ! "
          更改时，批处理:
            Confirm code:C+E00003 "单头汇率已修改，是否同步换算所有外币金额?"
